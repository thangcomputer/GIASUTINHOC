# ═══════════════════════════════════════════════════════════════════
# GIASUAI — CHỈ LÀ FILE MẪU (.env.example), KHÔNG CHẠY ĐƯỢC NẾU CHƯA THAY GIÁ TRỊ
#
# CẢNH BÁO: Nếu bạn copy nguyên nội dung này lên VPS thành `.env` mà VẪN
# để chữ REPLACE_... → Google đăng nhập sẽ báo invalid_client / OAuth
# client was not found; Gemini/OpenAI cũng không hoạt động.
#
# Bắt buộc: thay TOÀN Bộ REPLACE_* bằng giá trị thật từ Google Cloud /
# AI Studio, rồi JWT_SECRET ngẫu nhiên dài, ALLOWED_ORIGINS đúng domain.
#
# Sau khi sửa .env trên VPS: npm run build && pm2 restart giasuai --update-env
# (đổi VITE_* hoặc GOOGLE client → luôn cần npm run build)
# ═══════════════════════════════════════════════════════════════════

# --- Cổng & môi trường ---
# PORT dùng cho server Node; Vite (npm run dev) đọc PORT này để proxy /api — phải cùng một cổng (mặc định 5000).
# Hoặc đặt VITE_DEV_API_PROXY=http://127.0.0.1:XXXX nếu API chạy chỗ khác.
PORT=5000
# Trên máy dev: nên development (hoặc bỏ NODE_ENV) để CORS tự cho localhost + Vite proxy hoạt động.
NODE_ENV=production

# --- MongoDB (đổi tên DB nếu cần) ---
MONGODB_URI=mongodb://127.0.0.1:27017/giasuai

# --- JWT (bắt buộc đặt chuỗi ngẫu nhiên dài trên production) ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Thời gian không hoạt động tối đa trước khi API từ chối phiên (ms). Mặc định 3600000 = 1 giờ.
# SESSION_IDLE_MS=3600000

# --- CORS: domain frontend, cách nhau bằng dấu phẩy (không khoảng trắng thừa) ---
# Khi NODE_ENV không phải production, server tự thêm http://localhost:5173 và http://127.0.0.1:5173
# (và preview 4173) để đăng ký/đăng nhập từ Vite không bị chặn CORS.
# Nếu bạn vẫn để NODE_ENV=production trên máy dev: đặt CORS_ALLOW_LOCALHOST=true
# CORS_ALLOW_LOCALHOST=
ALLOWED_ORIGINS=https://giasutinhoc24h.com,https://www.giasutinhoc24h.com

# --- Gemini (chat AI) — hai dòng cùng một key ---
GEMINI_API_KEY=REPLACE_GEMINI_API_KEY
VITE_GEMINI_API_KEY=REPLACE_GEMINI_API_KEY

# --- OpenAI (chế độ OpenAI trong chat) — để trống nếu chưa dùng ---
OPENAI_API_KEY=

# --- Google đăng nhập (OAuth client loại Web) ---
# Bắt buộc khai báo đúng Client ID (không để REPLACE_...).
# Trên Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web):
#   Authorized JavaScript origins — thêm MỌI URL bạn mở trang (khác nhau từng dòng):
#     - Dev Vite: http://localhost:5173  và  http://127.0.0.1:5173
#     - Production: https://your-domain.com  (và www nếu dùng)
#   Thiếu origin → lỗi Error 400: origin_mismatch khi bấm "Tiếp tục với Google".
# Nếu màn hình OAuth đang "Testing": Google Cloud → APIs & Services → OAuth consent screen
#   → phần Test users — thêm email Google bạn dùng để đăng nhập thử.
VITE_GOOGLE_CLIENT_ID=REPLACE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=REPLACE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_GOOGLE_CLIENT_SECRET

# --- API URL frontend (tuỳ chọn) ---
# Để trống hoặc không khai báo: production dùng cùng origin với trang (khuyến nghị khi API + static cùng server).
# Chỉ set khi frontend và API khác domain, ví dụ:
# VITE_API_URL=https://api.example.com

# --- Trang chủ: video giới thiệu (YouTube — tuỳ chọn) ---
# Chỉ ID 11 ký tự (phần sau v= trong URL). Sau khi đổi: npm run build.
# VITE_HOME_INTRO_YOUTUBE_ID=

# --- Tavily (tìm web bổ sung cho RAG — tuỳ chọn) ---
# TAVILY_API_KEY=

# --- Thanh toán / nạp xu (tuỳ chọn) ---
# BILLING_WEBHOOK_SECRET=
# ALLOW_CLIENT_DEPOSIT không set hoặc true = cho phép client gọi mock deposit (mặc định true)
# ALLOW_CLIENT_DEPOSIT=true

# --- SePay + VietQR (nạp tự động khi có tiền vào TK) ---
# Đăng ký SePay, tạo Webhook URL trỏ tới: https://<domain>/api/webhooks/sepay
# Xác thực: SePay gửi header  Authorization: Apikey <giá trị SEPAY_API_KEY>
SEPAY_API_KEY=
# Tuỳ chọn — dùng nếu bạn bật xác thực HMAC trên SePay (chưa implement trong code mặc định)
SEPAY_SECRET_KEY=
# Mã ngân hàng VietQR (thường viết thường): acb, vcb, mbbank, ...
BANK_ID=acb
# Số tài khoản nhận tiền (chỉ số, không dấu cách)
ACCOUNT_NO=
# Tên chủ TK in hoa, khớp VietQR
ACCOUNT_NAME=

# --- Script VPS (node-ssh: check_app, vps_pull, deploy_vps, …) — chỉ dùng trên máy bạn ---
# Không hardcode trong repo; đặt trong .env local (đã gitignore) rồi chạy: node scripts/vps_pull.cjs
VPS_SSH_HOST=
VPS_SSH_USER=root
VPS_SSH_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# CÁCH “MỘT LẦN” — chỉ điền vài dòng rồi sinh full .env cho VPS:
# 1) Copy env.user-secrets.properties.example → env.user-secrets.properties
# 2) Điền GEMINI + Google Client ID + Secret (+ ALLOWED_ORIGINS nếu khác mặc định)
# 3) Chạy:  node scripts/gen-vps-env.cjs > vps.generated.env
# 4) Copy toàn bộ vps.generated.env → dán vào VPS /www/wwwroot/giasuai/.env
# 5) VPS: npm run build && pm2 restart giasuai --update-env
# (env.user-secrets.properties và vps.generated.env đã nằm trong .gitignore)
# ═══════════════════════════════════════════════════════════════════
