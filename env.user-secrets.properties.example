# ═══════════════════════════════════════════════════════════════════
# Bước 1: Copy file này → đổi tên thành:  env.user-secrets.properties
# Bước 2: Điền các dòng bên dưới (KHÔNG commit env.user-secrets.properties)
# Bước 3: Máy local trong thư mục GIASUAI chạy:
#        node scripts/gen-vps-env.cjs > vps.generated.env
# Bước 4: Mở vps.generated.env → copy toàn bộ → dán vào VPS /www/wwwroot/giasuai/.env
# Bước 5: Trên VPS:  npm run build && pm2 restart giasuai --update-env
# ═══════════════════════════════════════════════════════════════════

GEMINI_API_KEY=
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENAI_API_KEY=

# Domain site (CORS), cách nhau bằng dấu phẩy — sửa cho đúng domain bạn
ALLOWED_ORIGINS=https://giasutinhoc24h.com,https://www.giasutinhoc24h.com

# Tuỳ chọn (mặc định nếu bỏ trống)
# MONGODB_URI=mongodb://127.0.0.1:27017/giasuai
# PORT=4000
# JWT_EXPIRES_IN=7d
# TAVILY_API_KEY=
